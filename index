/**
 * PAGE: GENERATE VOUCHER
 */
const VoucherManager = () => {
  const [loading, setLoading] = useState(false);
  const [success, setSuccess] = useState(false);

  const handleGenerate = (e) => {
    e.preventDefault();
    setLoading(true);
    // Simulation of heavy batch generation
    setTimeout(() => {
      setLoading(false);
      setSuccess(true);
      setTimeout(() => setSuccess(false), 3000);
    }, 1500);
  };

  return (
    <div className="space-y-6">
      <div className="bg-white p-8 rounded-xl border border-slate-100 shadow-sm max-w-2xl mx-auto">
        <h2 className="text-xl font-bold mb-6 flex items-center gap-2 text-slate-800">
          <Ticket className="text-blue-600" /> Generate Batch Voucher
        </h2>
        <form onSubmit={handleGenerate} className="space-y-4">
          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-slate-700 mb-1">Nominal (Rp)</label>
              <input type="number" required defaultValue="50000" className="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div>
              <label className="block text-sm font-medium text-slate-700 mb-1">Jumlah Voucher</label>
              <input type="number" required defaultValue="100" className="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
          </div>
          <div>
            <label className="block text-sm font-medium text-slate-700 mb-1">Client / Tenant</label>
            <input type="text" readOnly value="PT Transportasi Maju" className="w-full px-4 py-2 bg-slate-50 border rounded-lg" />
          </div>
          <div>
            <label className="block text-sm font-medium text-slate-700 mb-1">Tanggal Kadaluarsa</label>
            <input type="date" required className="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
          </div>
          
          <button 
            type="submit" 
            disabled={loading}
            className="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg shadow-lg shadow-blue-200 transition-all flex items-center justify-center gap-2 disabled:opacity-50"
          >
            {loading ? <Loader2 className="animate-spin" /> : <Download size={20} />}
            Generate & Download PDF
          </button>
        </form>

        {success && (
          <div className="mt-4 p-4 bg-emerald-50 text-emerald-700 rounded-lg flex items-center gap-2 border border-emerald-100">
            <CheckCircle size={20} />
            Berhasil! Voucher sedang diproses dan diunduh.
          </div>
        )}
      </div>
    </div>
  );
};

/**
 * PAGE: SCANNER (OPERATOR)
 */
const OperatorScanner = () => {
  const [scanning, setScanning] = useState(true);
  const [result, setResult] = useState(null); // 'valid' | 'invalid' | null
  const [voucherData, setVoucherData] = useState(null);

  const simulateScan = (isValid) => {
    setScanning(false);
    if (isValid) {
      setResult('valid');
      setVoucherData({ id: 'V-882199', nominal: 50000, code: 'XJ-992-K', time: new Date().toLocaleTimeString() });
    } else {
      setResult('invalid');
      setVoucherData({ message: 'Voucher Sudah Digunakan atau Kode Tidak Dikenal' });
    }
  };

  const resetScanner = () => {
    setScanning(true);
    setResult(null);
    setVoucherData(null);
  };

  return (
    <div className="max-w-xl mx-auto h-[80vh] flex flex-col items-center justify-center text-center">
      {scanning ? (
        <div className="w-full space-y-8">
          <div className="relative aspect-square max-w-sm mx-auto bg-slate-900 rounded-2xl overflow-hidden border-4 border-slate-200 shadow-2xl flex items-center justify-center">
             {/* Mock Scan Box */}
            <div className="absolute inset-8 border-2 border-dashed border-white/30 rounded-lg animate-pulse" />
            <div className="absolute top-1/2 left-0 right-0 h-0.5 bg-red-500 shadow-[0_0_15px_rgba(239,68,68,1)] animate-scan-line" />
            <ScanQrCode size={64} className="text-white/20" />
            <div className="absolute bottom-4 text-white text-xs font-mono uppercase tracking-widest opacity-60">
              Menunggu QR Code...
            </div>
          </div>
          <div>
            <h2 className="text-2xl font-bold text-slate-800">Scan Voucher SPBU</h2>
            <p className="text-slate-500 mt-2">Arahkan kamera ke QR Code pada voucher fisik atau layar HP</p>
          </div>
          <div className="flex gap-4 justify-center">
            <button onClick={() => simulateScan(true)} className="px-4 py-2 bg-slate-100 text-slate-600 rounded-lg text-sm font-medium hover:bg-slate-200">Mock Valid</button>
            <button onClick={() => simulateScan(false)} className="px-4 py-2 bg-slate-100 text-slate-600 rounded-lg text-sm font-medium hover:bg-slate-200">Mock Invalid</button>
          </div>
        </div>
      ) : (
        <div className={`w-full p-8 rounded-3xl shadow-2xl transition-all animate-in zoom-in-95 duration-300 ${result === 'valid' ? 'bg-emerald-500 text-white' : 'bg-rose-500 text-white'}`}>
          <div className="flex justify-center mb-6">
            {result === 'valid' ? <CheckCircle size={100} strokeWidth={1.5} /> : <XCircle size={100} strokeWidth={1.5} />}
          </div>
          
          <h2 className="text-4xl font-black mb-2 uppercase italic tracking-tighter">
            {result === 'valid' ? 'VALID' : 'INVALID'}
          </h2>
          
          {result === 'valid' ? (
            <div className="space-y-4">
              <div className="bg-white/20 backdrop-blur-md rounded-2xl p-6 border border-white/10">
                <p className="text-sm uppercase font-bold opacity-80">Nominal Voucher</p>
                <h3 className="text-5xl font-black">Rp {voucherData.nominal.toLocaleString()}</h3>
              </div>
              <div className="grid grid-cols-2 gap-2 text-left">
                <div className="p-3 bg-white/10 rounded-xl">
                  <p className="text-[10px] uppercase font-bold opacity-70">Voucher ID</p>
                  <p className="font-mono font-bold text-sm">{voucherData.id}</p>
                </div>
                <div className="p-3 bg-white/10 rounded-xl">
                  <p className="text-[10px] uppercase font-bold opacity-70">Scan Time</p>
                  <p className="font-mono font-bold text-sm">{voucherData.time}</p>
                </div>
              </div>
            </div>
          ) : (
            <p className="text-xl font-medium opacity-90">{voucherData.message}</p>
          )}

          <button 
            onClick={resetScanner}
            className="mt-10 w-full bg-white text-slate-900 font-bold py-4 rounded-2xl shadow-xl hover:scale-[1.02] transition-transform active:scale-95"
          >
            KEMBALI KE SCANNER
          </button>
        </div>
      )}
    </div>
  );
};

